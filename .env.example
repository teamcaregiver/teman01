# Copy to .env and fill with your Supabase project values.

# Client-exposed (browser). Only VITE_* vars are bundled to the client.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# SERVER ONLY — service-role secret. Do NOT prefix with VITE_. Used only inside server functions.
SUPABASE_SECRET_KEY=sb_secret_xxx
